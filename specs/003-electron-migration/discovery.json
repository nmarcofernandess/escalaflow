  "patterns": [
    "Pattern: snake_case ponta a ponta — DB columns = JSON keys = TypeScript interfaces. NEVER camelCase conversion.",
    "Pattern: Singleton DB connection via getDb() lazy init with WAL + foreign_keys pragmas.",
    "Pattern: Hono routes are thin controllers — all SQL logic inline, no separate repository/service layer.",
    "Pattern: API services in frontend use centralized api.ts client (fetch wrapper) — all services import {api}.",
    "Pattern: useApiData custom hook for data fetching (loading/error/reload state machine).",
    "Pattern: Zustand store is minimal — only setorAtivoId. Most state is local to page components.",
    "Pattern: shadcn/ui components at @/components/ui/ with @/ alias resolving to src/.",
    "Pattern: Custom components at @/componentes/ (PT-BR naming), pages at @/paginas/.",
    "Pattern: Motor receives db instance as parameter (dependency injection) — makes worker adaptation straightforward.",
    "Pattern: Motor exports gerarProposta() and validador exports validarEscala() — pure functions with DB param.",
    "Pattern: Seed file uses createTables() + idempotent INSERT IF NOT EXISTS pattern.",
    "Pattern: BrowserRouter used for routing — will work with Electron file:// protocol via HashRouter or base config.",
    "Pattern: main.tsx wraps App in StrictMode + BrowserRouter + TooltipProvider + Toaster.",
    "Pattern: components.json configures shadcn with new-york style, @/ aliases.",
    "Pattern: vite.config.ts has proxy '/api' -> 'http://localhost:3333' — to be eliminated."
  ],
  "risks": [
    {
      "id": "RISK-01",
      "severity": "HIGH",
      "title": "better-sqlite3 native module compilation in Electron",
      "description": "better-sqlite3 is a native Node.js addon. Electron bundles its own Node.js version, so the native module must be rebuilt against Electron's headers. electron-rebuild or electron-vite's externalizeDepsPlugin handles this, but it can fail silently.",
      "mitigation": "Use externalizeDepsPlugin in electron.vite.config.ts, configure asarUnpack for .node files in electron-builder.yml, test with npm run pack before dist."
    },
    {
      "id": "RISK-02",
      "severity": "HIGH",
      "title": "Worker thread loading native module in packaged app",
      "description": "Worker threads in Electron packaged apps have trouble resolving native modules because the ASAR archive filesystem doesn't support them. The worker must find the unpacked better-sqlite3 binary.",
      "mitigation": "Worker opens its OWN DB connection (never shares with main). Use ?modulePath query from electron-vite for worker resolution. Test in both dev and pack modes."
    },
    {
      "id": "RISK-03",
      "severity": "MEDIUM",
      "title": "BrowserRouter vs file:// protocol",
      "description": "BrowserRouter uses HTML5 history API which requires a web server. Electron loads from file:// in production which doesn't support pushState. Routes will 404 on refresh.",
      "mitigation": "Switch from BrowserRouter to HashRouter in main.tsx. HashRouter uses URL hash (#/) which works with file:// protocol. Minimal change: one import swap."
    },
    {
      "id": "RISK-04",
      "severity": "MEDIUM",
      "title": "Import path breakage during migration",
      "description": "~45 files import from '@escalaflow/shared' (workspace package). After migration this becomes a relative path or tsconfig alias. Any missed import = compile error.",
      "mitigation": "Run find-and-replace for '@escalaflow/shared' in all moved files. Configure tsconfig paths in electron-vite for both main and renderer. Run npx tsc --noEmit after each phase."
    },
    {
      "id": "RISK-05",
      "severity": "MEDIUM",
      "title": "shadcn/ui components.json path resolution",
      "description": "components.json uses '@/' aliases for components, utils, hooks. If electron-vite doesn't resolve these identically, shadcn CLI (npx shadcn add) will break for future component additions.",
      "mitigation": "Move components.json to project root (or src/renderer/), update aliases to match electron.vite.config.ts renderer resolve config."
    },
    {
      "id": "RISK-06",
      "severity": "LOW",
      "title": "Tailwind content paths change",
      "description": "tailwind.config.js content points to './index.html' and './src/**/*.{ts,tsx}'. After move to src/renderer/, paths need updating.",
      "mitigation": "Update content paths in tailwind.config.js (or ts) to match new renderer structure. electron-vite provides tailwind integration docs."
    },
    {
      "id": "RISK-07",
      "severity": "LOW",
      "title": "DB path in dev vs production",
      "description": "Current DB path uses __dirname relative resolution. Electron needs app.getPath('userData') which only works after app.whenReady(). In dev mode, may want DB in project root.",
      "mitigation": "Use conditional path: if (app.isPackaged) use userData, else use project root data/ folder. Initialize DB after app.whenReady()."
    },
    {
      "id": "RISK-08",
      "severity": "LOW",
      "title": "Electron bundle size (~150MB+)",
      "description": "Electron apps include Chromium + Node.js, resulting in large bundles. This is cosmetic for a desktop app but may surprise the operator.",
      "mitigation": "Acceptable for desktop use case. Can optimize later with asar compression, tree-shaking unused Chromium features."
    }
  ],
