            ],
            "exact_changes": [
              "Import: useState, useEffect from react",
              "Define ColorTheme type: 'zinc' | 'blue' | 'green' | 'violet'",
              "useState for colorTheme (default: 'zinc')",
              "useEffect on mount (empty deps array):",
              "  - Read localStorage key 'escalaflow-color-theme'",
              "  - If value exists and is valid, set state and apply to DOM",
              "  - If 'zinc', remove data-color-theme attribute",
              "  - Else setAttribute('data-color-theme', theme) on document.documentElement",
              "setColorTheme function:",
              "  - Update state",
              "  - Save to localStorage with key 'escalaflow-color-theme'",
              "  - If theme === 'zinc': document.documentElement.removeAttribute('data-color-theme')",
              "  - Else: document.documentElement.setAttribute('data-color-theme', theme)",
              "Return: { colorTheme, setColorTheme }"
            ],
            "patterns_from": [
              "src/renderer/src/hooks/useApiData.ts (hook structure with useState + useEffect)"
            ],
            "verification": {
