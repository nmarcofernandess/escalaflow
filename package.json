{
  "name": "escalaflow",
  "productName": "EscalaFlow",
  "version": "1.8.0",
  "description": "App desktop offline para geração automática de escalas de trabalho em varejo",
  "author": "Marco Fernandes",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "clean": "rm -rf out tmp .vite",
    "clean:dev": "npm run clean && npm run dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ia:eval": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx tests/ia/evals/run-evals.ts",
    "test:ia:live": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx tests/ia/live/live-smoke.ts",
    "ia:chat": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx tests/ia/live/ia-chat-cli.ts",
    "db:reset": "node scripts/db-reset.mjs",
    "db:extract-seed": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx scripts/extract-db-to-seed.ts",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "solver:build": "cd solver && pyinstaller escalaflow-solver.spec --distpath ../solver-bin/ --clean --noconfirm",
    "solver:test:db": "python3 scripts/solver_test_db.py --setor-id 1 --solve-mode rapido --nivel-rigor ALTO",
    "solver:test:real": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx scripts/test-solver-real.ts",
    "solver:test:parity": "vitest run tests/main/solver-cli-parity.spec.ts",
    "solver:test": "npm run solver:test:real",
    "solver:cli": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx scripts/solver-cli.ts",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "model:download": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx scripts/download-embedding-model.ts",
    "knowledge:seed": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron ./node_modules/.bin/tsx scripts/knowledge-seed.ts",
    "mcp:dev": "npx tsx mcp-server/index.ts",
    "mcp:build": "cd mcp-server && bun install && cd .. && bun build --compile mcp-server/index.ts --outfile mcp-bin/escalaflow-mcp",
    "mcp:install": "cd mcp-server && npm install"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.30",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@egoist/tipc": "^0.3.2",
    "@electric-sql/pglite": "^0.3.15",
    "@hookform/resolvers": "^5.2.2",
    "@huggingface/transformers": "^3.8.1",
    "@openrouter/ai-sdk-provider": "^6.0.0-alpha.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.97",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.564.0",
    "next-themes": "^0.4.6",
    "node-llama-cpp": "^3.17.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@rollup/rollup-darwin-arm64": "^4.57.1"
  }
}
