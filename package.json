    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
