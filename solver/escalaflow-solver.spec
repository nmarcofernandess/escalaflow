# -*- mode: python ; coding: utf-8 -*-
"""
PyInstaller spec for escalaflow-solver binary.

Build:
  cd solver && pyinstaller escalaflow-solver.spec --distpath ../solver-bin/ --clean --noconfirm
"""

a = Analysis(
    ['solver_ortools.py'],
    pathex=[],
    binaries=[],
    datas=[],
    hiddenimports=[],
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[],
    noarchive=False,
    optimize=0,
)
pyz = PYZ(a.pure)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.datas,
    [],
    name='escalaflow-solver',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=[],
    runtime_tmpdir=None,
    console=True,
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
    collect_all='ortools',
)
